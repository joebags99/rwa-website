# Production Environment Configuration
# Copy this file to .env or .env.local and fill in your values

# Server Configuration
NODE_ENV=production
PORT=5000

# Session Configuration
SESSION_SECRET=your-secure-random-session-secret-here-change-this

# YouTube API (for live video feeds on the homepage / campaign pages)
# Without these the site shows a "Watch on YouTube" link instead of live videos.
YOUTUBE_API_KEY=your-youtube-api-key-here
CHANNEL_ID=your-youtube-channel-id-here
# Playlist IDs power the homepage video sections (found in the playlist URL after ?list=)
CRIMSON_COURT_PLAYLIST_ID=PLul61JiSKZm_AKoWZ8KzcFF4J1FcaCpuo
DM_ADVICE_PLAYLIST_ID=your-dm-advice-playlist-id-here
FEATURED_PLAYLIST_ID=your-featured-playlist-id-here

# Security Settings
# Set to true if behind HTTPS proxy (recommended for production)
TRUST_PROXY=true

# Admin Configuration
# Default admin password is 'rollwithadvantage'
# Change this immediately after first login!
