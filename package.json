{
  "name": "roll-with-advantage",
  "version": "1.0.0",
  "description": "A D&D actual play and DM advice website with admin functionality",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:admin": "terser public/js/admin.js --compress --mangle --output public/js/admin.min.js --source-map url=admin.min.js.map",
    "build": "npm run build:admin",
    "prod": "NODE_ENV=production node server.js",
    "test": "echo \"No tests yet\" && exit 0",
    "lint": "echo \"No linter configured\" && exit 0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "docx": "^9.4.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.18.1",
    "file-saver": "^2.0.5",
    "marked": "^15.0.7",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "terser": "^5.44.1"
  },
  "engines": {
    "node": ">=14.0.0"
  },
